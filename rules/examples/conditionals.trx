^Conditionals|description:Intent Core conditional chaining examples _|

#mode|branch2 _|

!?|#mode:branch1
    !|log:Branch 1 _|
_|
?!|#mode:branch2
    !|log:Branch 2 _|
_|
?!|#mode:branch3
    !|log:Branch 3 _|
_|
?!|
    !|log:Final fallback _|
_|

#state|offline _|
-!?|#state:online
    !|log:System is online _|
_|
-?!|#state:sleep
    !|log:Still running _|
_|
-?!|
    !|log:System unresponsive _|
_|
